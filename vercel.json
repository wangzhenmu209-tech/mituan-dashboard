{
  "version": 2,
  "name": "mituan-dashboard",
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "env": {
    "FEISHU_APP_ID": "@feishu-app-id",
    "FEISHU_APP_SECRET": "@feishu-app-secret"
  }
}
